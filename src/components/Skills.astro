---
const skillGroups = [
  { label: "Languages", skills: ["Python", "JavaScript", "Java", "C++", "LaTeX"] },
  { label: "ML / Data", skills: ["PyTorch", "Pandas", "Mathematica"] },
  { label: "Web", skills: ["HTML/CSS", "Node.js", "Pug.js", "Astro"] },
  { label: "Tools", skills: ["Git", "Linux", "Docker"] },
  { label: "Research", skills: ["Academic Writing", "ML Development", "Teaching"] },
];
---

<section class="section">
  <h2 class="section-title">Skills</h2>
  <div class="skills-container">
    {skillGroups.map((group) => (
      <div class="skill-group">
        <div class="skill-label">{group.label}</div>
        <div class="tags">
          {group.skills.map((skill) => (
            <span class="tag">{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.2rem;
  }

  .skill-group {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
  }
</style>
