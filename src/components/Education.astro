---
const education = [
  { period: "2019 – 2025", degree: "Ph.D. in Computer Science", school: "Oregon State University" },
  { period: "2015 – 2019", degree: "BS in Applied Math / Physics", school: "University of Rochester" },
];
---

<section class="section">
  <h2 class="section-title">Education</h2>
  <div class="timeline">
    {education.map((ed) => (
      <div class="timeline-item">
        <div class="timeline-date">{ed.period}</div>
        <div class="timeline-title">{ed.degree}</div>
        <div class="timeline-body">{ed.school}</div>
      </div>
    ))}
  </div>
</section>
